#!/usr/bin/env python3
"""Remote workspace helper for agents.

The tool keeps local workspaces mapped to remote directories and exposes compact
SSH/rsync commands. It also supports short aliases such as `remote1 pwd` through
small shell wrappers generated by setup.sh.
"""

from __future__ import annotations

import argparse
import shlex
import subprocess
import sys
from pathlib import Path
from typing import Any

try:
    import tomllib
except ModuleNotFoundError:  # pragma: no cover
    tomllib = None  # type: ignore[assignment]


TOOL_DIR = Path(__file__).resolve().parent
PROJECT_DIR = TOOL_DIR.parent
DEFAULT_CONFIG_DIR = TOOL_DIR / "configs"
DEFAULT_CONFIG = DEFAULT_CONFIG_DIR / "config.toml"
DEFAULT_EXCLUDES = [
    ".git/",
    ".venv/",
    "__pycache__/",
    "*.pyc",
    "outputs/",
    "output/",
    "logs/",
    "checkpoints/",
    "wandb/",
    "runs/",
    "tmp/",
]


class ConfigError(RuntimeError):
    pass


def die(message: str, code: int = 2) -> None:
    print(f"tool4remote: {message}", file=sys.stderr)
    raise SystemExit(code)


def run_checked(argv: list[str], *, dry_run: bool = False) -> int:
    print("+ " + " ".join(shlex.quote(part) for part in argv), flush=True)
    if dry_run:
        return 0
    return subprocess.call(argv)


def capture(argv: list[str]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(argv, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)


def expand_path(value: str, base: Path) -> str:
    path = Path(value).expanduser()
    if not path.is_absolute():
        path = base / path
    return str(path)


def load_toml(path: Path) -> dict[str, Any]:
    if tomllib is None:
        die("Python 3.11+ is required")
    if not path.exists():
        die(f"config not found: {path}")
    with path.open("rb") as fh:
        return tomllib.load(fh)


def config_paths(path_text: str | None) -> list[Path]:
    if path_text:
        path = Path(path_text).expanduser().resolve()
        if path.is_dir():
            paths = []
            direct = path / "config.toml"
            if direct.exists():
                paths.append(direct)
            paths.extend(sorted(path.glob("*/config.toml")))
            if not paths:
                die(f"no config.toml found under {path}")
            return paths
        return [path]

    paths = []
    if DEFAULT_CONFIG.exists():
        paths.append(DEFAULT_CONFIG.resolve())
    paths.extend(sorted(DEFAULT_CONFIG_DIR.glob("*/config.toml")))
    if not paths:
        die(f"no config found; run {TOOL_DIR / 'setup.sh'}")
    return paths


def normalize_config(data: dict[str, Any], path: Path) -> dict[str, Any]:
    base = path.parent

    remotes = data.get("remotes")
    workspaces = data.get("workspaces")

    if not remotes and all(key in data for key in ("host", "remote_dir", "local_dir")):
        remotes = {
            "remote1": {
                "host": data["host"],
                "ssh_config": data.get("ssh_config", "configs/ssh_config"),
                "ssh_options": data.get("ssh_options", []),
            }
        }
        workspaces = {
            "default": {
                "remote": "remote1",
                "local_dir": data["local_dir"],
                "remote_dir": data["remote_dir"],
                "excludes": data.get("excludes", DEFAULT_EXCLUDES),
                "rsync_flags": data.get("rsync_flags", ["-az", "--info=progress2"]),
                "status_commands": data.get("status_commands", []),
            }
        }

    if not isinstance(remotes, dict) or not remotes:
        raise ConfigError(f"{path} must define [remotes.<name>]")
    if not isinstance(workspaces, dict) or not workspaces:
        raise ConfigError(f"{path} must define [workspaces.<name>]")

    defaults = data.get("defaults", {})
    default_workspace = defaults.get("workspace") or next(iter(workspaces))

    normalized_remotes: dict[str, dict[str, Any]] = {}
    for name, remote in remotes.items():
        if not isinstance(remote, dict):
            raise ConfigError(f"remote {name!r} must be a table")
        host = remote.get("host")
        if not host:
            raise ConfigError(f"remote {name!r} is missing host")
        ssh_config = remote.get("ssh_config")
        normalized_remotes[name] = {
            "name": name,
            "host": host,
            "ssh_config": expand_path(ssh_config, base) if ssh_config else None,
            "ssh_options": list(remote.get("ssh_options", [])),
        }

    normalized_workspaces: dict[str, dict[str, Any]] = {}
    for name, workspace in workspaces.items():
        if not isinstance(workspace, dict):
            raise ConfigError(f"workspace {name!r} must be a table")
        remote_name = workspace.get("remote")
        if remote_name not in normalized_remotes:
            raise ConfigError(f"workspace {name!r} references unknown remote {remote_name!r}")
        local_dir = workspace.get("local_dir")
        remote_dir = workspace.get("remote_dir")
        if not local_dir or not remote_dir:
            raise ConfigError(f"workspace {name!r} needs local_dir and remote_dir")
        normalized_workspaces[name] = {
            "name": name,
            "remote": remote_name,
            "local_dir": expand_path(local_dir, PROJECT_DIR),
            "remote_dir": remote_dir,
            "excludes": list(workspace.get("excludes", DEFAULT_EXCLUDES)),
            "rsync_flags": list(workspace.get("rsync_flags", ["-az", "--info=progress2"])),
            "status_commands": list(workspace.get("status_commands", [])),
        }

    if default_workspace not in normalized_workspaces:
        raise ConfigError(f"default workspace {default_workspace!r} does not exist")

    return {
        "path": str(path),
        "defaults": {"workspace": default_workspace},
        "remotes": normalized_remotes,
        "workspaces": normalized_workspaces,
    }


def load_config(path_text: str | None) -> dict[str, Any]:
    paths = config_paths(path_text)
    configs = [normalize_config(load_toml(path), path) for path in paths]
    merged: dict[str, Any] = {
        "path": ", ".join(str(path) for path in paths),
        "defaults": {"workspace": configs[0]["defaults"]["workspace"]},
        "remotes": {},
        "workspaces": {},
    }
    for cfg in configs:
        for name, rmt in cfg["remotes"].items():
            if name in merged["remotes"]:
                raise ConfigError(f"duplicate remote name {name!r} across config files")
            merged["remotes"][name] = rmt
        for name, ws in cfg["workspaces"].items():
            if name in merged["workspaces"]:
                raise ConfigError(f"duplicate workspace name {name!r} across config files")
            merged["workspaces"][name] = ws
    if merged["defaults"]["workspace"] not in merged["workspaces"]:
        merged["defaults"]["workspace"] = next(iter(merged["workspaces"]))
    return merged


def workspace(cfg: dict[str, Any], name: str | None) -> dict[str, Any]:
    selected = name or cfg["defaults"]["workspace"]
    try:
        return cfg["workspaces"][selected]
    except KeyError:
        die(f"unknown workspace {selected!r}; run `tool4remote list`")


def remote(cfg: dict[str, Any], name: str) -> dict[str, Any]:
    try:
        return cfg["remotes"][name]
    except KeyError:
        die(f"unknown remote {name!r}; run `tool4remote list`")


def ssh_base(rmt: dict[str, Any]) -> list[str]:
    argv = ["ssh"]
    if rmt.get("ssh_config"):
        argv.extend(["-F", rmt["ssh_config"]])
    argv.extend(rmt.get("ssh_options", []))
    argv.append(rmt["host"])
    return argv


def rsync_base(ws: dict[str, Any], rmt: dict[str, Any]) -> list[str]:
    argv = ["rsync", *ws["rsync_flags"]]
    if rmt.get("ssh_config") or rmt.get("ssh_options"):
        ssh_cmd = ["ssh"]
        if rmt.get("ssh_config"):
            ssh_cmd.extend(["-F", rmt["ssh_config"]])
        ssh_cmd.extend(rmt.get("ssh_options", []))
        argv.extend(["-e", " ".join(shlex.quote(part) for part in ssh_cmd)])
    for pattern in ws["excludes"]:
        argv.append(f"--exclude={pattern}")
    return argv


def local_target(ws: dict[str, Any]) -> str:
    return str(Path(ws["local_dir"]).expanduser()) + "/"


def remote_target(ws: dict[str, Any], rmt: dict[str, Any]) -> str:
    return f"{rmt['host']}:{ws['remote_dir'].rstrip('/')}/"


def remote_command(ws: dict[str, Any], command: str) -> str:
    return f"cd {shlex.quote(ws['remote_dir'])} && {command}"


def state_file(ws: dict[str, Any]) -> Path:
    return Path(ws["local_dir"]) / ".tool4remote" / "state"


def write_state(ws: dict[str, Any], rmt: dict[str, Any]) -> None:
    path = state_file(ws)
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(
        f"remote={ws['remote']}\nhost={rmt['host']}\nremote_dir={ws['remote_dir']}\n",
        encoding="utf-8",
    )


def local_has_content(ws: dict[str, Any]) -> bool:
    local = Path(ws["local_dir"])
    if not local.exists():
        return False
    return any(item.name != ".tool4remote" for item in local.iterdir())


def local_is_initialized(ws: dict[str, Any]) -> bool:
    return state_file(ws).exists()


def local_git_status(ws: dict[str, Any], dry_run: bool) -> None:
    local = Path(ws["local_dir"])
    if not local.exists():
        print("[local] directory does not exist")
        return
    if (local / ".git").exists():
        run_checked(["git", "-C", str(local), "status", "--short"], dry_run=dry_run)
        return
    entries = [item.name for item in sorted(local.iterdir(), key=lambda p: p.name) if item.name != ".tool4remote"]
    if entries:
        shown = ", ".join(entries[:20])
        suffix = " ..." if len(entries) > 20 else ""
        print(f"[local] non-git workspace entries: {shown}{suffix}")
    else:
        print("[local] empty non-git workspace")


def remote_has_content(ws: dict[str, Any], rmt: dict[str, Any]) -> bool:
    remote_dir = shlex.quote(ws["remote_dir"])
    command = (
        f"if [ ! -d {remote_dir} ]; then echo MISSING; "
        f"elif find {remote_dir} -mindepth 1 -maxdepth 1 -print -quit | grep -q .; "
        "then echo NONEMPTY; else echo EMPTY; fi"
    )
    result = capture([*ssh_base(rmt), command])
    if result.returncode != 0:
        die(f"failed to inspect remote workspace:\n{result.stderr.strip()}")
    return result.stdout.strip() == "NONEMPTY"


def ensure_pull_safe(ws: dict[str, Any], args: argparse.Namespace) -> None:
    if args.force or args.dry_run or local_is_initialized(ws):
        return
    if local_has_content(ws):
        die(
            "local workspace already has content and is not initialized by tool4remote.\n"
            f"local_dir: {ws['local_dir']}\n"
            "Run `tool4remote status` to inspect it, move/backup the directory, or retry pull with --force."
        )


def ensure_push_safe(ws: dict[str, Any], rmt: dict[str, Any], args: argparse.Namespace) -> None:
    if args.force or args.dry_run or local_is_initialized(ws):
        return
    if remote_has_content(ws, rmt):
        die(
            "remote workspace already has content and this local workspace is not initialized by tool4remote.\n"
            f"remote: {rmt['host']}:{ws['remote_dir']}\n"
            "Pull first, choose another remote_dir, or retry push with --force after confirming the contents."
        )


def cmd_list(cfg: dict[str, Any], args: argparse.Namespace) -> int:
    print(f"config: {cfg['path']}")
    print("remotes:")
    for name, rmt in cfg["remotes"].items():
        config = f" ssh_config={rmt['ssh_config']}" if rmt.get("ssh_config") else ""
        print(f"  {name}: host={rmt['host']}{config}")
    print("workspaces:")
    for name, ws in cfg["workspaces"].items():
        marker = " (default)" if name == cfg["defaults"]["workspace"] else ""
        print(f"  {name}{marker}: {ws['remote']}:{ws['remote_dir']} <-> {ws['local_dir']}")
    return 0


def cmd_init(cfg: dict[str, Any], args: argparse.Namespace) -> int:
    targets = [workspace(cfg, args.workspace)] if args.workspace else cfg["workspaces"].values()
    for ws in targets:
        print(f"[{ws['name']}] local:  {ws['local_dir']}")
        print(f"[{ws['name']}] remote: {ws['remote']}:{ws['remote_dir']}")
        if not args.dry_run:
            Path(ws["local_dir"]).mkdir(parents=True, exist_ok=True)
    return 0


def cmd_pull(cfg: dict[str, Any], args: argparse.Namespace) -> int:
    ws = workspace(cfg, args.workspace)
    rmt = remote(cfg, ws["remote"])
    ensure_pull_safe(ws, args)
    Path(ws["local_dir"]).mkdir(parents=True, exist_ok=True)
    argv = rsync_base(ws, rmt)
    if args.delete:
        argv.append("--delete")
    argv.extend([remote_target(ws, rmt), local_target(ws)])
    code = run_checked(argv, dry_run=args.dry_run)
    if code == 0 and not args.dry_run:
        write_state(ws, rmt)
    return code


def cmd_push(cfg: dict[str, Any], args: argparse.Namespace) -> int:
    ws = workspace(cfg, args.workspace)
    rmt = remote(cfg, ws["remote"])
    if not args.dry_run and not Path(ws["local_dir"]).exists():
        die(f"local_dir does not exist: {ws['local_dir']}; run `tool4remote init` or `tool4remote pull`")
    ensure_push_safe(ws, rmt, args)
    argv = rsync_base(ws, rmt)
    if args.delete:
        argv.append("--delete")
    argv.extend([local_target(ws), remote_target(ws, rmt)])
    code = run_checked(argv, dry_run=args.dry_run)
    if code == 0 and not args.dry_run:
        write_state(ws, rmt)
    return code


def cmd_run(cfg: dict[str, Any], args: argparse.Namespace) -> int:
    ws = workspace(cfg, args.workspace)
    rmt = remote(cfg, ws["remote"])
    command = " ".join(args.command).strip()
    if not command:
        die("missing remote command")
    argv = [*ssh_base(rmt), remote_command(ws, command)]
    return run_checked(argv, dry_run=args.dry_run)


def cmd_remote(cfg: dict[str, Any], args: argparse.Namespace) -> int:
    rmt = remote(cfg, args.remote)
    ws = workspace(cfg, args.workspace)
    if ws["remote"] != args.remote:
        matches = [candidate for candidate in cfg["workspaces"].values() if candidate["remote"] == args.remote]
        ws = matches[0] if matches else ws
    command = " ".join(args.command).strip() or "pwd"
    argv = [*ssh_base(rmt), remote_command(ws, command)]
    return run_checked(argv, dry_run=args.dry_run)


def cmd_status(cfg: dict[str, Any], args: argparse.Namespace) -> int:
    ws = workspace(cfg, args.workspace)
    rmt = remote(cfg, ws["remote"])
    print(f"[workspace] {ws['name']}")
    print(f"[local] {ws['local_dir']}")
    local_git_status(ws, args.dry_run)
    commands = ws["status_commands"] or [
        "pwd",
        "git branch --show-current 2>/dev/null || true",
        "git status --short 2>/dev/null | head -80 || true",
        "df -h . | tail -1",
        "nvidia-smi --query-gpu=index,name,memory.used,memory.total,utilization.gpu --format=csv,noheader 2>/dev/null || true",
    ]
    remote_status = " && ".join(f"echo {shlex.quote('[' + c.split()[0] + ']')} && {c}" for c in commands)
    return run_checked([*ssh_base(rmt), remote_command(ws, remote_status)], dry_run=args.dry_run)


def cmd_tail(cfg: dict[str, Any], args: argparse.Namespace) -> int:
    if args.lines < 1 or args.lines > 5000:
        die("--lines must be between 1 and 5000")
    ws = workspace(cfg, args.workspace)
    rmt = remote(cfg, ws["remote"])
    command = f"tail -n {args.lines} {shlex.quote(args.file)}"
    return run_checked([*ssh_base(rmt), remote_command(ws, command)], dry_run=args.dry_run)


def cmd_gpu(cfg: dict[str, Any], args: argparse.Namespace) -> int:
    selected = args.remote or remote(cfg, workspace(cfg, args.workspace)["remote"])["name"]
    rmt = remote(cfg, selected)
    command = (
        "nvidia-smi "
        "--query-gpu=index,name,memory.used,memory.total,utilization.gpu,temperature.gpu "
        "--format=csv"
    )
    return run_checked([*ssh_base(rmt), command], dry_run=args.dry_run)


def cmd_tmux(cfg: dict[str, Any], args: argparse.Namespace) -> int:
    ws = workspace(cfg, args.workspace)
    rmt = remote(cfg, ws["remote"])
    session = shlex.quote(args.session)
    actions = {
        "new": f"tmux new -s {session}",
        "attach": f"tmux attach -t {session}",
        "ls": "tmux ls",
    }
    return run_checked([*ssh_base(rmt), remote_command(ws, actions[args.action])], dry_run=args.dry_run)


def add_workspace_arg(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("-w", "--workspace", help="Workspace name from [workspaces.<name>]")


def build_parser(cfg: dict[str, Any] | None = None) -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="tool4remote",
        description="Manage local/remote workspaces for agent-driven SSH workflows.",
    )
    parser.add_argument("-c", "--config", help=f"Config path, default {DEFAULT_CONFIG}")
    parser.add_argument("--dry-run", action="store_true", help="Print commands without executing")
    sub = parser.add_subparsers(dest="cmd")

    list_p = sub.add_parser("list", help="List remotes and workspaces")
    list_p.set_defaults(func=cmd_list)

    init_p = sub.add_parser("init", help="Create local workspace directories")
    add_workspace_arg(init_p)
    init_p.set_defaults(func=cmd_init)

    pull_p = sub.add_parser("pull", help="Sync remote workspace to local workspace")
    add_workspace_arg(pull_p)
    pull_p.add_argument("--delete", action="store_true", help="Delete local files missing on remote")
    pull_p.add_argument("--force", action="store_true", help="Allow pulling into a non-empty uninitialized local workspace")
    pull_p.set_defaults(func=cmd_pull)

    push_p = sub.add_parser("push", help="Sync local workspace to remote workspace")
    add_workspace_arg(push_p)
    push_p.add_argument("--delete", action="store_true", help="Delete remote files missing locally")
    push_p.add_argument("--force", action="store_true", help="Allow pushing to a non-empty remote from an uninitialized local workspace")
    push_p.set_defaults(func=cmd_push)

    run_p = sub.add_parser("run", help="Run a command in the remote workspace")
    add_workspace_arg(run_p)
    run_p.add_argument("command", nargs=argparse.REMAINDER)
    run_p.set_defaults(func=cmd_run)

    status_p = sub.add_parser("status", help="Show compact local and remote status")
    add_workspace_arg(status_p)
    status_p.set_defaults(func=cmd_status)

    tail_p = sub.add_parser("tail", help="Tail a remote file inside the remote workspace")
    add_workspace_arg(tail_p)
    tail_p.add_argument("file")
    tail_p.add_argument("-n", "--lines", type=int, default=120)
    tail_p.set_defaults(func=cmd_tail)

    gpu_p = sub.add_parser("gpu", help="Show compact nvidia-smi output")
    add_workspace_arg(gpu_p)
    gpu_p.add_argument("-r", "--remote", help="Remote name")
    gpu_p.set_defaults(func=cmd_gpu)

    tmux_p = sub.add_parser("tmux", help="Open or inspect tmux in the remote workspace")
    add_workspace_arg(tmux_p)
    tmux_p.add_argument("action", choices=["new", "attach", "ls"])
    tmux_p.add_argument("session", nargs="?", default="exp")
    tmux_p.set_defaults(func=cmd_tmux)

    if cfg:
        for name in cfg["remotes"]:
            remote_p = sub.add_parser(name, help=f"Run a command on remote alias {name}")
            add_workspace_arg(remote_p)
            remote_p.add_argument("command", nargs=argparse.REMAINDER)
            remote_p.set_defaults(func=cmd_remote, remote=name)

    return parser


def main() -> int:
    pre = argparse.ArgumentParser(add_help=False)
    pre.add_argument("-c", "--config")
    pre_args, _ = pre.parse_known_args()
    try:
        cfg = load_config(pre_args.config)
    except ConfigError as exc:
        die(str(exc))

    parser = build_parser(cfg)
    args = parser.parse_args()
    if not args.cmd:
        parser.print_help()
        return 0
    return args.func(cfg, args)


if __name__ == "__main__":
    raise SystemExit(main())
